{
  "manifest_version": 3,
  "name": "ColorCat",
  "version": "1.0",
  "description": "Shoot elements to change their background color randomly!",
  "action": {
    "default_title": "Toggle ColorCat"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "permissions": ["scripting"]
}
